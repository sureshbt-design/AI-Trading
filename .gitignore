# Python

__pycache__/
*.py[cod]
*$py.class

# Virtual Environment
.venv/
venv/

# PATCC generated files
01-Projects/PATCC/Data/cache/
01-Projects/PATCC/Logs/
01-Projects/PATCC/Reports/

# Cursor
.cursor/

# VS Code
.vscode/

# Logs
*.log

# OS Files
.DS_Store
Thumbs.db

# Reports (optional)
# Uncomment if you don't want generated reports tracked
# Reports/*.txt

# PATCC generated reports
Reports/latest/
Reports/archive/
Reports/errors/

# Preserve selected monthly research snapshots
!Reports/monthly/
!Reports/monthly/**

# PATCC generated data and runtime files
Data/cache/
Data/raw/**/*
Data/processed/**/*
Data/models/**/*
Logs/**/*

# Preserve directory placeholders
!Data/raw/**/.gitkeep
!Data/processed/.gitkeep
!Data/models/.gitkeep
!Logs/.gitkeep
